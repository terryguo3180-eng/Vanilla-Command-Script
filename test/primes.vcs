is_prime(n: Int) -> Bool:
    if n < 2:
        return false
    if n == 2 or n == 3:
        return true
    if n % 2 == 0:
        return false

    i: Int = 3
    while i * i <= n:
        if n % i == 0:
            return false
        i += 2

    return true

main():
    for i: Int = 0; i <= 100000; i += 1:
        if is_prime(i):
            tell i
